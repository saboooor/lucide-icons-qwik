{
  "name": "lucide-icons-qwik",
  "version": "0.577.2-1",
  "description": "Lucide icon library package for Qwik applications",
  "author": {
    "name": "saboooor",
    "url": "https://saboor.ca"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/saboooor/lucide-icons-qwik.git"
  },
  "license": "LICENSE",
  "keywords": [
    "icon",
    "icons",
    "lucide",
    "qwik"
  ],
  "main": "./lib/index.qwik.mjs",
  "qwik": "./lib/index.qwik.mjs",
  "types": "./lib-types/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.qwik.mjs",
      "require": "./lib/index.qwik.cjs",
      "types": "./lib-types/index.d.ts"
    }
  },
  "files": [
    "lib",
    "lib-types"
  ],
  "engines": {
    "node": ">=16.8.0 <18.0.0 || >=18.11"
  },
  "private": false,
  "type": "module",
  "scripts": {
    "build": "pnpm build.icons && qwik build",
    "build.icons": "node --trace-warnings build.js",
    "build.lib": "vite build --mode lib",
    "build.types": "tsc --emitDeclarationOnly",
    "lint": "eslint \"src/**/*.ts*\"",
    "release": "np",
    "start": "vite --open --mode ssr",
    "sync-version": "node --trace-warnings sync-version.js",
    "qwik": "qwik",
    "test": "echo no tests for now"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.3.5",
    "eslint": "10.0.3",
    "eslint-plugin-qwik": "2.0.0-beta.27",
    "globals": "^17.4.0",
    "lucide": "^0.577.0",
    "np": "^11.0.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1",
    "undici": "7.22.0",
    "vite": "7.3.1",
    "yargs": "^18.0.0",
    "@qwik.dev/core": "2.0.0-beta.27"
  }
}
